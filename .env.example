# Bölgenin Uzmanı — environment template. Copy to `.env` and fill real values.
# `.env` is gitignored; this file (.env.example) is committed.

# PUBLIC (client-readable; VITE_ prefix inlines into the browser bundle).
# Safe to expose. From Supabase dashboard → Project Settings → API.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx   # publishable key (or legacy anon JWT)

# SERVER-ONLY (NO VITE_ prefix — never shipped to the client).
# From dashboard → Project Settings → API → service_role secret. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
